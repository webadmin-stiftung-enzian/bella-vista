{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1440px"
		},
		"spacing": {
			"blockGap": true,
			"customSpacingSize": true,
			"margin": false,
			"padding": false,
			"spacingScale": {
				"operator": "*",
				"increment": 2,
				"steps": 7,
				"mediumStep": 2,
				"unit": "rem"
			},
			"spacingSizes": [],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"blocks": {
			"core/image": {
				"dimensions": {
					"units": [
						"px",
						"em",
						"rem",
						"vh",
						"vw",
						"%"
					]
				}
			}
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#272727",
					"name": "dark grey",
					"slug": "dark-grey"
				},
				{
					"color": "#FFFFFF",
					"name": "white",
					"slug": "white"
				},
				{
					"color": "#F5F5F5",
					"name": "light grey",
					"slug": "light-grey"
				},
				{
					"color": "#000000",
					"name": "black",
					"slug": "black"
				},
				{
					"color": "#EFE9E7",
					"name": "brown grey",
					"slug": "brown-grey"
				},
				{
					"color": "#F5F2F1",
					"name": "light brown grey",
					"slug": "light-brown-grey"
				},
				{
					"color": "#DFD3CF",
					"name": "dark brown grey",
					"slug": "dark-brown-grey"
				},
				{
					"color": "#090402",
					"name": "dark brown",
					"slug": "dark-brown"
				},
				{
					"color": "#FF6D2F",
					"name": "accent orange",
					"slug": "accent orange"
				}
			]
		},
		"spacing": {
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"custom": {
			"lineHeight": {
				"xs": 1,
				"sm": 1.25,
				"md": 1.5,
				"lg": 1.75
			},
			"letterSpacing": {
				"xs": "-0.05em",
				"sm": "-0.025em",
				"md": "0em",
				"lg": "0.025em",
				"xl": "0.05em"
			},
			"borderRadius": {
				"none": "0",
				"sm": "8px",
				"md": "16px",
				"lg": "32px",
				"full": "9999px"
			},
			"breakpoints": {
				"mobile": "640px",
				"tablet": "768px",
				"desktop": "1024px"
			},
			"headingSizes": {
				"h1-large": {
					"fontSize": "clamp(2.5rem, 1.4286rem + 2.8571vw, 4rem)",
					"lineHeight": "1.35"
				},
				"h2-large": {
					"fontSize": "clamp(2.5rem, 1.4286rem + 2.8571vw, 4rem)",
					"lineHeight": "1.35"
				},
				"h3-large": {
					"fontSize": "clamp(1.5rem, 1.1429rem + 0.9524vw, 2rem)",
					"lineHeight": "1.3"
				},
				"h4-large": {
					"fontSize": "clamp(1.5rem, 1.1429rem + 0.9524vw, 2rem)",
					"lineHeight": "1.35"
				},
				"h1-small": {
					"fontSize": "clamp(1.75rem, 0.8571rem + 2.381vw, 3rem);",
					"lineHeight": "1.2"
				},
				"h2-small": {
					"fontSize": "clamp(1.75rem, 0.8571rem + 2.381vw, 3rem);",
					"lineHeight": "1.2"
				},
				"h3-small": {
					"fontSize": "clamp(1rem, 0.5714rem + 0.9524vw, 1.5rem);",
					"lineHeight": "1.1"
				},
				"h4-small": {
					"fontSize": "clamp(1rem, 0.5714rem + 0.9524vw, 1.5rem);",
					"lineHeight": "1.1"
				}

			}
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system-font"
				},
				{
					"fontFamily": "'PP Neue Montreal', sans-serif",
					"name": "PP Neue Montreal",
					"slug": "pp-neue-montreal",
					"fontFace": [
						{
							"fontFamily": "PP Neue Montreal",
							"fontDisplay": "swap",
							"fontWeight": "300",
							"fontStyle": "normal",
							"src": [
								"file:./assets/files/fonts/PPNeueMontreal-Light.woff2"
							]
						},
						{
							"fontFamily": "PP Neue Montreal",
							"fontDisplay": "swap",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": [
								"file:./assets/files/fonts/PPNeueMontreal-Regular.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'PP Fragment Glare', sans-serif",
					"name": "PP Fragment Glare",
					"slug": "pp-fragment-glare",
					"fontFace": [
						{
							"fontFamily": "PP Fragment Glare",
							"fontWeight": "300",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/files/fonts/PPFragment-GlareLight.woff2"
							]
						},
						{
							"fontFamily": "PP Fragment Glare",
							"fontWeight": "300",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/files/fonts/PPFragment-GlareLightItalic.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "13px"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "20px"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "36px"
				},
				{
					"name": "Extra Large",
					"slug": "x-large",
					"size": "42px"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"typography": {
			"fontSize": "1rem",
			"lineHeight": "1.2"
		},
		"color": {
			"text": "#090402",
			"background": "#EFE9E7",
			"link": "#38160A"
		},
		"spacing": {
			"blockGap": "2rem",
			"margin": {
				"blockStart": "2rem",
				"blockEnd": "2rem",
				"left": "0"
			},
			"padding": {
				"left": "2rem",
				"right": "2rem"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"fontWeight": "300",
					"fontSize": "4rem",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"fontSize": "3rem",
					"fontWeight": "300",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "'PP Neue Montreal', sans-serif",
					"fontWeight": "300",
					"fontSize": "2rem",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "'PP Neue Montreal', sans-serif",
					"fontWeight": "300",
					"fontSize": "2rem",
					"lineHeight": "1.3"
				}
			},
			"button": {
				"border": {
					"radius": "var(--wp--custom--border-radius--lg)"
				},
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"fontWeight": "300"
				},
				"color": {
					"text": "#090402",
					"background": "var(--wp--preset--color--light-brown-grey)"
				},
				":hover": {
					"color": {
						"text": "#090402",
						"background": "#FF6D2F"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--light-brown-grey)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "#666666"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		},
		"blocks": {
			"core/group": {
				"color": {
					"text": "#090402",
					"link": "#777777"
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "#FF6D2F",
							"style": "solid",
							"width": "1px"
						},
						"color": {
							"text": "#FF6D2F",
							"background": "transparent"
						},
						":hover": {
							"color": {
								"text": "#090402",
								"background": "#FF6D2F"
							}
						}
					},
					"outline-2": {
						"border": {
							"color": "#090402",
							"style": "solid",
							"width": "1px"
						},
						"color": {
							"text": "##090402",
							"background": "transparent"
						},
						":hover": {
							"color": {
								"text": "#090402",
								"background": "#FF6D2F"
							}
						}
					}
				}
			},
			"core/heading": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"fontWeight": "300",
					"lineHeight": "md"
				}
			},
			"core/paragraph": {
				"typography": {
					"lineHeight": "lg",
					"fontFamily": "PP Fragment Glare",
					"fontWeight": "300"
				}
			},
			"core/details": {
				"typography": {
					"fontFamily": "'PP Neue Montreal', sans-serif",
					"fontWeight": "300",
					"lineHeight": "md"
				},
				"color": {
					"text": "#090402",
					"background": "var(--wp--preset--color--light-brown-grey)"
				},
				"spacing": {
					"padding": {
						"top": "1.25rem",
						"bottom": "1.25rem",
						"left": "1.25rem",
						"right": "1.25rem"
					}
				}
			},
			"core/image": {
				"css": "& img { width: 100%; height: auto; }",
				"elements": {
					"caption": {
						"spacing": {
							"margin": {
								"top": "1rem"
							}
						},
						"typography": {
							"fontFamily": "'PP Neue Montreal', sans-serif",
							"lineHeight": "140%",
							"fontSize": "0.925rem",
							"letterSpacing": "0.02em"
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"fontWeight": "300",
					"fontSize": "1rem"
				}
			},
			"core/table": {
				"typography": {
					"fontFamily": "'PP Neue Montreal', sans-serif",
					"lineHeight": "md",
					"fontSize": "0.925rem",
					"letterSpacing": "0.02em"
				},
				"color": {
					"text": "rgba(0, 0, 0, 0.75)",
					"background": "transparent"
				},
				"spacing": {
					"padding": {
						"top": "0.5rem",
						"bottom": "0.5rem",
						"left": "0.5rem",
						"right": "0.5rem"
					}
				},
				"border": {
					"bottom": {
						"color": "rgba(0, 0, 0, 0.5)",
						"style": "solid",
						"width": "1px"
					}
				}
			},
			"core/paragraph": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"lineHeight": "158%",
					"fontWeight": "400",
					"fontSize": "1.125rem",
					"letterSpacing": "0.025em"
				}
			},
			"core/list": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"lineHeight": "158%",
					"fontWeight": "400",
					"fontSize": "1.125rem",
					"letterSpacing": "0.025em"
				}
			},
			"core/list-item": {
				"typography": {
					"fontFamily": "PP Fragment Glare",
					"lineHeight": "158%",
					"fontWeight": "400",
					"fontSize": "1.125rem",
					"letterSpacing": "0.025em"
				},
				"spacing": {
					"margin": {
						"blockStart": "0.5rem",
						"blockEnd": "0.5rem",
						"top": "0.75rem",
						"bottom": "0.75rem"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	],
	"version": 3
}